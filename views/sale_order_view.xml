<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tambah section SPK di Form Sale Order -->
    <record id="view_sale_order_form_inherit_produksi" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.produksi</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='note']" position="before">
                <group string="🏭 Order Produksi (SPK) Terkait" invisible="state != 'sale'">
                    <field name="produksi_order_ids" nolabel="1" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="template_id"/>
                            <field name="jumlah_target"/>
                            <field name="satuan_produksi"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'done'"
                                   decoration-info="state in ('draft', 'confirmed')"
                                   decoration-warning="state == 'in_progress'"
                                   decoration-danger="state == 'cancel'"/>
                        </tree>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
