<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- Form View: Template Produksi -->
    <record id="view_produksi_template_form" model="ir.ui.view">
        <field name="name">produksi.template.form</field>
        <field name="model">produksi.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Misal: Resep Susu Kedelai Original"/></h1>
                    </div>
                    <group>
                        <group string="Informasi Produk">
                            <field name="product_id"/>
                            <field name="jumlah_langkah"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Deskripsi">
                            <field name="deskripsi" nolabel="1" placeholder="Penjelasan singkat proses produksi..."/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Langkah-Langkah Proses">
                            <field name="step_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" placeholder="Misal: Perendaman Kedelai"/>
                                    <field name="durasi_estimasi" widget="float_time"/>
                                    <field name="instruksi"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Bahan Baku Default">
                            <field name="bahan_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="nama_bahan" placeholder="Misal: Kedelai Kering"/>
                                    <field name="jumlah"/>
                                    <field name="satuan"/>
                                    <field name="keterangan"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View: Template Produksi -->
    <record id="view_produksi_template_tree" model="ir.ui.view">
        <field name="name">produksi.template.tree</field>
        <field name="model">produksi.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="product_id"/>
                <field name="jumlah_langkah"/>
            </tree>
        </field>
    </record>

    <!-- Action: Template Produksi -->
    <record id="action_produksi_template" model="ir.actions.act_window">
        <field name="name">Template Produksi</field>
        <field name="res_model">produksi.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Buat Template Produksi Pertama Anda!
            </p>
            <p>
                Template berisi langkah-langkah proses dan bahan baku default
                untuk setiap produk. Contoh: Resep Susu Kedelai Original.
            </p>
        </field>
    </record>

</odoo>
