        <record id="template_susu_kedelai_original" model="produksi.template">
            <field name="name">Resep Susu Kedelai Original</field>
            <field name="product_id" ref="product_susu_kedelai_original"/>
            <field name="deskripsi">Proses pembuatan susu kedelai original tanpa tambahan perasa. Rasa natural kedelai murni.</field>
        </record>

      
        <record id="step_ori_1" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">10</field>
            <field name="name">Sortasi &amp; Pencucian Kedelai</field>
            <field name="durasi_estimasi">1.0</field>
            <field name="instruksi">1. Pilih kedelai yang berkualitas baik, buang yang rusak/busuk
2. Cuci kedelai dengan air bersih sebanyak 3x bilasan
3. Pastikan tidak ada kotoran atau batu kecil</field>
        </record>
        <record id="step_ori_2" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">20</field>
            <field name="name">Perendaman Kedelai</field>
            <field name="durasi_estimasi">8.0</field>
            <field name="instruksi">1. Rendam kedelai dalam air bersih selama 8-12 jam (semalam)
2. Perbandingan air dan kedelai = 3:1
3. Kedelai yang sudah terendam sempurna akan mengembang 2x lipat
4. Buang air rendaman setelah selesai</field>
        </record>
        <record id="step_ori_3" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">30</field>
            <field name="name">Penggilingan / Blending</field>
            <field name="durasi_estimasi">1.5</field>
            <field name="instruksi">1. Masukkan kedelai yang sudah direndam ke mesin penggiling/blender
2. Tambahkan air panas (80°C) dengan perbandingan 8:1 terhadap kedelai kering
3. Giling hingga halus (±3-5 menit per batch)
4. Pastikan tidak ada gumpalan kasar</field>
        </record>
        <record id="step_ori_4" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">40</field>
            <field name="name">Penyaringan</field>
            <field name="durasi_estimasi">1.0</field>
            <field name="instruksi">1. Saring bubur kedelai menggunakan kain saring halus (80-100 mesh)
2. Peras ampas hingga sari kedelai keluar maksimal
3. Ampas bisa disimpan untuk olahan lain (tempe gembus, dll)
4. Pastikan tidak ada ampas yang lolos ke sari kedelai</field>
        </record>
        <record id="step_ori_5" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">50</field>
            <field name="name">Perebusan / Pasteurisasi</field>
            <field name="durasi_estimasi">1.0</field>
            <field name="instruksi">1. Masak sari kedelai dengan api sedang hingga mendidih (100°C)
2. Aduk terus menerus agar tidak gosong di bagian bawah
3. Setelah mendidih, kecilkan api dan masak 15-20 menit lagi
4. Buang busa yang muncul di permukaan
5. Tambahkan gula secukupnya (opsional)</field>
        </record>
        <record id="step_ori_6" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">60</field>
            <field name="name">Pendinginan</field>
            <field name="durasi_estimasi">2.0</field>
            <field name="instruksi">1. Dinginkan susu kedelai hingga suhu ruang (±30°C)
2. Bisa menggunakan water bath untuk mempercepat
3. Jangan langsung dikemas saat masih panas</field>
        </record>
        <record id="step_ori_7" model="produksi.template.step">
            <field name="template_id" ref="template_susu_kedelai_original"/>
            <field name="sequence">70</field>
            <field name="name">Pengemasan</field>
            <field name="durasi_estimasi">1.5</field>
            <field name="instruksi">1. Siapkan kemasan botol/cup yang sudah disterilkan
2. Isi kemasan menggunakan mesin filling atau manual
3. Tutup rapat-rapat
4. Beri label (nama produk, tanggal produksi, tanggal kadaluarsa)
5. Simpan di suhu dingin (4°C)</field>
        </record>

